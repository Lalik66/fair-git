// Prisma schema for Fair Marketplace
// Uses SQLite for development

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Users table
model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  googleId            String?   @unique @map("google_id")
  firstName           String?   @map("first_name")
  lastName            String?   @map("last_name")
  phone               String?
  role                String    @default("user") // admin, vendor, user
  preferredLanguage   String    @default("az") @map("preferred_language") // az, en
  passwordHash        String?   @map("password_hash")
  mustChangePassword  Boolean   @default(false) @map("must_change_password")
  lastLogin           DateTime? @map("last_login")
  isActive            Boolean   @default(true) @map("is_active")
  lastLatitude        Float?    @map("last_latitude")
  lastLongitude       Float?    @map("last_longitude")
  locationUpdatedAt   DateTime? @map("location_updated_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  vendorProfile       VendorProfile?
  adminLogs           AdminLog[]
  reviewedApplications Application[] @relation("ReviewedBy")
  aboutUsUpdates      AboutUsContent[]
  following           UserFollow[] @relation("UserFollowing")
  followers           UserFollow[] @relation("UserFollowers")
  inviteLinks         InviteLink[]
  conversationsAsParticipant1 Conversation[] @relation("ConversationParticipant1")
  conversationsAsParticipant2 Conversation[] @relation("ConversationParticipant2")
  sentMessages        Message[] @relation("MessageSender")
  reactionsSent       Reaction[] @relation("ReactionSender")
  reactionsReceived   Reaction[] @relation("ReactionRecipient")

  @@map("users")
}

// Vendor profiles table
model VendorProfile {
  id                  String    @id @default(uuid())
  userId              String    @unique @map("user_id")
  companyName         String?   @map("company_name")
  businessDescription String?   @map("business_description")
  logoUrl             String?   @map("logo_url")
  productCategory     String?   @map("product_category") // food_beverages, handicrafts, clothing, accessories, other
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  productImages       VendorProductImage[]
  applications        Application[]
  bookings            Booking[]

  @@map("vendor_profiles")
}

// Vendor product images table
model VendorProductImage {
  id              String        @id @default(uuid())
  vendorProfileId String        @map("vendor_profile_id")
  imageUrl        String        @map("image_url")
  orderIndex      Int           @default(0) @map("order_index")
  createdAt       DateTime      @default(now()) @map("created_at")

  // Relations
  vendorProfile   VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  @@map("vendor_product_images")
}

// Fairs table
model Fair {
  id              String    @id @default(uuid())
  name            String
  descriptionAz   String?   @map("description_az")
  descriptionEn   String?   @map("description_en")
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  locationAddress String?   @map("location_address")
  mapCenterLat    Float?    @map("map_center_lat")
  mapCenterLng    Float?    @map("map_center_lng")
  bannerImageUrl  String?   @map("banner_image_url")
  status          String    @default("upcoming") // upcoming, active, completed, archived
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  archivedAt      DateTime? @map("archived_at")

  // Relations
  applications    Application[]
  bookings        Booking[]

  @@map("fairs")
  @@index([status])
  @@index([status, startDate])
}

// Vendor houses table
model VendorHouse {
  id              String    @id @default(uuid())
  houseNumber     String    @unique @map("house_number")
  areaSqm         Float?    @map("area_sqm")
  price           Float?
  description     String?
  latitude        Float
  longitude       Float
  panorama360Url  String?   @map("panorama_360_url")
  isEnabled       Boolean   @default(true) @map("is_enabled")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  applications    Application[]
  bookings        Booking[]

  @@map("vendor_houses")
  @@index([isEnabled])
}

// Facilities table
model Facility {
  id          String   @id @default(uuid())
  name        String
  type        String   // restaurant, cafe, kids_zone, restroom, taxi, bus_stop, parking
  description String?
  latitude    Float
  longitude   Float
  photoUrl    String?  @map("photo_url")
  icon        String?
  color       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("facilities")
  @@index([type])
}

// Applications table
model Application {
  id              String    @id @default(uuid())
  vendorProfileId String    @map("vendor_profile_id")
  fairId          String    @map("fair_id")
  vendorHouseId   String    @map("vendor_house_id")
  status          String    @default("pending") // pending, approved, rejected
  adminNotes      String?   @map("admin_notes")
  rejectionReason String?   @map("rejection_reason")
  submittedAt     DateTime  @default(now()) @map("submitted_at")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedById    String?   @map("reviewed_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  vendorProfile   VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  fair            Fair          @relation(fields: [fairId], references: [id], onDelete: Cascade)
  vendorHouse     VendorHouse   @relation(fields: [vendorHouseId], references: [id], onDelete: Cascade)
  reviewedBy      User?         @relation("ReviewedBy", fields: [reviewedById], references: [id])
  booking         Booking?

  @@map("applications")
}

// Bookings table
model Booking {
  id              String   @id @default(uuid())
  applicationId   String   @unique @map("application_id")
  vendorProfileId String   @map("vendor_profile_id")
  vendorHouseId   String   @map("vendor_house_id")
  fairId          String   @map("fair_id")
  bookingStatus   String   @default("pending") @map("booking_status") // pending, approved, completed, archived
  startDate       DateTime @map("start_date")
  endDate         DateTime @map("end_date")
  isArchived      Boolean  @default(false) @map("is_archived")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  application     Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  vendorProfile   VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  vendorHouse     VendorHouse   @relation(fields: [vendorHouseId], references: [id], onDelete: Cascade)
  fair            Fair          @relation(fields: [fairId], references: [id], onDelete: Cascade)

  @@map("bookings")
  @@index([fairId, bookingStatus, isArchived])
  @@index([vendorHouseId])
}

// Admin activity logs table
model AdminLog {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  action    String
  details   String?
  ipAddress String?  @map("ip_address")
  timestamp DateTime @default(now())

  // Relations
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}

// About Us content table
model AboutUsContent {
  id          String   @id @default(uuid())
  sectionKey  String   @unique @map("section_key")
  contentAz   String?  @map("content_az")
  contentEn   String?  @map("content_en")
  updatedById String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  updatedBy   User?    @relation(fields: [updatedById], references: [id])

  @@map("about_us_content")
}

// Site contact info (phone, email, social links) - editable in Admin, single row
model SiteContactInfo {
  id           String   @id @default(uuid())
  phone        String?
  email        String?
  facebookUrl  String?  @map("facebook_url")
  instagramUrl String?  @map("instagram_url")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("site_contact_info")
}

// User follow relationships (asymmetric - like Twitter/Instagram)
model UserFollow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("user_follows")
  @@index([followerId])
  @@index([followingId])
}

// Conversation between two mutual friends (1:1 messaging)
// Uses normalized participant order: participant1 < participant2 (lexicographically)
model Conversation {
  id           String    @id @default(uuid())
  participant1 String    @map("participant_1")
  participant2 String    @map("participant_2")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  user1        User      @relation("ConversationParticipant1", fields: [participant1], references: [id], onDelete: Cascade)
  user2        User      @relation("ConversationParticipant2", fields: [participant2], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([participant1, participant2])
  @@index([participant1])
  @@index([participant2])
  @@index([updatedAt])
  @@map("conversations")
}

// Chat message in a conversation
model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  senderId       String       @map("sender_id")
  content        String
  createdAt      DateTime     @default(now()) @map("created_at")
  readAt         DateTime?    @map("read_at")
  isDeleted      Boolean      @default(false) @map("is_deleted")

  // Relations
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([conversationId, senderId, readAt])
  @@index([senderId])
  @@map("messages")
}

// Invite links for friend invitations
model InviteLink {
  id          String   @id @default(uuid())
  token       String   @unique
  createdById String   @map("created_by_id")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@map("invite_links")
  @@index([token])
  @@index([createdById])
}

// Reaction (2GIS-style quick emoji reactions between friends)
model Reaction {
  id          String   @id @default(uuid())
  senderId    String   @map("sender_id")
  recipientId String   @map("recipient_id")
  emoji       String
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  sender    User @relation("ReactionSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("ReactionRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("reactions")
}
